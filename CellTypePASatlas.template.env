# ==========================================
# CRISPR Projects - Environment Template
# ==========================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to your local environment (e.g. in our case we specify paths on scicore HPC cluster and name it CRISPR_projects.scicore.env).
# 2. Replace the placeholder paths in the "Base Directories" section with your actual paths.
# 3. DO NOT commit your actual personalized .env file to version control.

# --- Base Directories (USER MUST MODIFY THESE) ---
LAB_GROUP_DIR=/path/to/your/shared/group/folder/
MAIN_PROJECT_DIR=/path/to/your/shared/group/CRISPR_projects/
WF_DIR=/path/to/your/local/Projects/CRISPR_projects/WF/
UCSC_TRACKS_DIR=/path/to/your/shared/ucsc_tracks/
HUMAN_ANNOTATION_DIR=/path/to/your/shared/Genomes/homo_sapiens/

# =========================================================================
# THE PATHS BELOW ARE AUTO-GENERATED BASED ON THE BASE DIRECTORIES ABOVE.
# ONLY MODIFY THESE IF YOU ARE CHANGING THE CORE PROJECT STRUCTURE.
# =========================================================================

# --- UCSC Subdirectories ---
UCSC_TRACKFILES_DIR=${UCSC_TRACKS_DIR}trackfiles/
UCSC_TRACKHUBS_DIR=${UCSC_TRACKS_DIR}trackhubs/

# --- Shared Project Subdirectories ---
SHARED_PROJECT_DIR=${MAIN_PROJECT_DIR}
TEMP_DIR=${SHARED_PROJECT_DIR}temp_dir/
SLURM_DIR=${TEMP_DIR}slurm/
SLURM_SCRIPTS_DIR=${SHARED_PROJECT_DIR}scripts/
FIGURES_DIR=${SHARED_PROJECT_DIR}figures/
TABLES_DIR=${SHARED_PROJECT_DIR}tables/
FASTQ_DIR=${SHARED_PROJECT_DIR}input_fastq/
METADATA_DIR=${SHARED_PROJECT_DIR}metadata/
WF_RUNS_DIR=${SHARED_PROJECT_DIR}wf_runs/

# --- Genome Annotation Files ---
HUMAN_GENOME_FILE=${HUMAN_ANNOTATION_DIR}GRCh38.primary_assembly.genome.fa
HUMAN_CHROM_SIZES_FILE=${HUMAN_ANNOTATION_DIR}hg38.chrom.sizes
HUMAN_ANNOTATION_FILE=${HUMAN_ANNOTATION_DIR}hg38_v42/gencode.v42.annotation.gtf
HUMAN_BASIC_ANNOTATION_FILE=${HUMAN_ANNOTATION_DIR}hg38_v42/gencode.v42.basic.annotation.gtf
HUMAN_RNACENTRAL_ANNOTATION_FILE=${HUMAN_ANNOTATION_DIR}hg38_v42/homo_sapiens.GRCh38.gff3.gz
HUMAN_ENRICHED_ANNOTATION_FILE=${HUMAN_ANNOTATION_DIR}hg38_v42/enriched.gencode.v42.annotation.gtf
HUMAN_REFSEQ_ANNOTATION_FILE=${HUMAN_ANNOTATION_DIR}hg38_RefSeq/GRCh38_latest_genomic.gtf
HUMAN_REFSEQ_CHRNAMES=${HUMAN_ANNOTATION_DIR}hg38_RefSeq/RefSeq_chrNames.tsv
HUMAN_PRERRNA_FILE=${HUMAN_ANNOTATION_DIR}pre_rRNA.from_GENBANK.fasta
HUMAN_POLYASITE_ATLAS=${HUMAN_ANNOTATION_DIR}hg38_v42/atlas.clusters.3.0.GRCh38.GENCODE_42.bed.gz
HUMAN_TANDEM_PAS=${HUMAN_ANNOTATION_DIR}hg38_v42/atlas.clusters.3.0.GRCh38.GENCODE_42.terminal_exons.bed